{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": "data_exchange",
  "screens": [
    {
      "id": "EDIT_ITEM",
      "title": "Edit Item",
      "terminal": true,
      "data": {
        "item_name": {
          "type": "textInput",
          "label": "Item Name",
          "required": true,
          "max-chars": 80,
          "default": "{{data.item_name}}"
        },
        "item_price": {
          "type": "textInput",
          "label": "Price (₹)",
          "required": false,
          "input-type": "number",
          "max-chars": 10,
          "default": "{{data.item_price}}"
        },
        "item_quantity": {
          "type": "dropdown",
          "label": "Quantity",
          "required": true,
          "data-source": [
            { "id": "1", "title": "1" },
            { "id": "2", "title": "2" },
            { "id": "3", "title": "3" },
            { "id": "4", "title": "4" },
            { "id": "5", "title": "5" },
            { "id": "6", "title": "6" },
            { "id": "7", "title": "7" },
            { "id": "8", "title": "8" },
            { "id": "9", "title": "9" },
            { "id": "10", "title": "10" }
          ],
          "default": "{{data.item_quantity}}"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "edit_form",
            "children": [
              {
                "type": "TextInput",
                "name": "item_name",
                "label": "Item Name",
                "required": true
              },
              {
                "type": "TextInput",
                "name": "item_price",
                "label": "Price (₹)",
                "required": false,
                "input-type": "number"
              },
              {
                "type": "Dropdown",
                "name": "item_quantity",
                "label": "Quantity",
                "required": true,
                "data-source": [
                  { "id": "1", "title": "1" },
                  { "id": "2", "title": "2" },
                  { "id": "3", "title": "3" },
                  { "id": "4", "title": "4" },
                  { "id": "5", "title": "5" },
                  { "id": "6", "title": "6" },
                  { "id": "7", "title": "7" },
                  { "id": "8", "title": "8" },
                  { "id": "9", "title": "9" },
                  { "id": "10", "title": "10" }
                ]
              }
            ]
          }
        ]
      },
      "footer": {
        "type": "TextFooter",
        "text": "SmartOrder"
      },
      "buttons": [
        {
          "type": "primary",
          "action": "data_exchange",
          "title": "Save Changes"
        },
        {
          "type": "secondary",
          "action": "close",
          "title": "Cancel"
        }
      ]
    }
  ]
}
